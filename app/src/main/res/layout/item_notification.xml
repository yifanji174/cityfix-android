<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/notification_layout"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:padding="3dp"
        app:srcCompat="@drawable/rounded_button_5"
        tools:layout_editor_absoluteX="-1dp"
        tools:layout_editor_absoluteY="-1dp" />

    <ImageView
        android:id="@+id/notification_icon"
        android:layout_width="53dp"
        android:layout_height="50dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@+id/notification_layout"
        app:layout_constraintStart_toStartOf="@+id/notification_layout"
        app:layout_constraintTop_toTopOf="@+id/notification_layout"
        app:layout_constraintVertical_bias="0.235"
        app:srcCompat="@drawable/notification" />

    <TextView
        android:id="@+id/notification_title"
        android:layout_width="246dp"
        android:layout_height="26dp"
        android:layout_marginTop="2dp"
        android:text="Notification_title"
        android:textColor="#00695C"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@+id/notification_icon"
        app:layout_constraintTop_toTopOf="@+id/notification_layout" />

    <TextView
        android:id="@+id/notification_description"
        android:layout_width="265dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:text="The report you marked changed statues!"
        android:textColor="#748982"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/notification_layout"
        app:layout_constraintStart_toEndOf="@+id/notification_icon"
        app:layout_constraintTop_toBottomOf="@+id/notification_title"
        app:layout_constraintVertical_bias="0.857" />

    <TextView
        android:id="@+id/notification_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="05-01-2025"
        android:textColor="#748982"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/notification_title"
        app:layout_constraintEnd_toEndOf="@+id/notification_layout"
        app:layout_constraintTop_toTopOf="@+id/notification_title"
        app:layout_constraintVertical_bias="0.181" />

    <TextView
        android:id="@+id/notification_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="12:51"
        android:textColor="#748982"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@+id/notification_date"
        app:layout_constraintStart_toStartOf="@+id/notification_date"
        app:layout_constraintTop_toBottomOf="@+id/notification_date" />

    <ImageView
        android:id="@+id/Notification_redDot"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="@+id/notification_icon"
        app:layout_constraintTop_toTopOf="@+id/notification_icon"
        app:srcCompat="@drawable/new_notification"
        tools:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
